{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others --names \"backend,frontend\" --prefix-colors \"cyan,green\" \"cross-env API_ONLY=true tsx server.ts\" \"wait-on http://localhost:3000/api/health && vite --host 0.0.0.0 --configLoader runner\"",
    "dev:frontend": "vite --host 0.0.0.0 --configLoader runner",
    "dev:backend": "tsx server.ts",
    "start": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "lightweight-charts": "^4.2.3",
    "lucide-react": "^0.546.0",
    "mongodb": "^7.2.0",
    "mongoose": "^9.5.0",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.4",
    "playwright": "^1.60.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0",
    "uuid": "^14.0.0",
    "vite": "^6.2.0",
    "ws": "^8.20.0"
  },
  "overrides": {
    "node-domexception": "^1.0.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.34.8",
    "@rollup/rollup-linux-x64-musl": "^4.34.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.3"
  }
}
