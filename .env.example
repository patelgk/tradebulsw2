# Server
NODE_ENV=production
PORT=3000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# Dhan live market feed
# Keep these server-side only. Do not prefix live tokens with VITE_.
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# Market feed controls
DISABLE_DHAN_WS=false
DISABLE_DHAN_AUTOFETCH=false
OPTION_CHAIN_WS_STRIKE_RANGE=10
DHAN_SUBSCRIBE_BATCH_SIZE=50

# Development simulator safety
# These must stay false in production.
ENABLE_MARKET_SIMULATOR=false
TEST_MODE=false

# Email settings for withdrawal notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_EMAIL=

# Optional Upstox settings if enabled by your backend routes
UPSTOX_CLIENT_ID=
UPSTOX_CLIENT_SECRET=
UPSTOX_REDIRECT_URI=
UPSTOX_ACCESS_TOKEN=
